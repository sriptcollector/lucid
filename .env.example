# ============================================================
#  Lucid — advanced overrides (OPTIONAL)
# ============================================================
#
#  You normally DO NOT need this file.
#
#  The setup wizard (run "python start.py") collects everything Lucid needs
#  and saves it to data/config.json. That is the normal way to configure Lucid,
#  and you can change any of it later under Settings in the web app.
#
#  This file is only for advanced users who want to override a setting via an
#  environment variable — for example, on a headless server. To use it, copy
#  this file to ".env" and uncomment the lines you want. Anything set here takes
#  precedence over the wizard's saved values.
#
#  Use placeholders only — never commit real secrets.
# ============================================================


# --- Anthropic (analysis) ---------------------------------------
# Your Anthropic API key. Normally set in the wizard.
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Claude model used for analysis.
#ANALYSIS_MODEL=claude-opus-4-8


# --- Transcription (speech -> text) -----------------------------
# Which backend turns audio into text.
#   faster_whisper  = Local, free, fully private (default)
#   openai          = OpenAI cloud Whisper API (needs OPENAI_API_KEY)
#   deepgram        = Deepgram cloud API (needs DEEPGRAM_API_KEY)
#TRANSCRIBE_BACKEND=faster_whisper

# Local model size (only used when TRANSCRIBE_BACKEND=faster_whisper).
# One of: tiny | base | small | medium | large-v3
# Bigger = more accurate but slower and more memory.
#WHISPER_MODEL=base

# Cloud transcription keys (only needed for the matching backend above).
#OPENAI_API_KEY=
#DEEPGRAM_API_KEY=


# --- Translation ------------------------------------------------
# Translate transcripts into this language before analysis.
# Use a language name like "English" or "Spanish", or "none" to keep the
# original language.
#TRANSLATE_TO=English


# --- Server -----------------------------------------------------
# Network address and port Lucid listens on.
#HOST=0.0.0.0
#PORT=8000


# --- Plaud cloud sync -------------------------------------------
# Whether Lucid automatically pulls new recordings from your Plaud cloud.
# Normally turned on by the wizard once you connect your Plaud account.
#PLAUD_CLOUD_ENABLED=true
# How often (in seconds) Lucid checks your Plaud cloud for new recordings.
# Lower = quicker pickup but more frequent requests.
#PLAUD_POLL_INTERVAL=300


# --- Private web link (Cloudflare tunnel) -----------------------
# Whether Lucid auto-deploys a private Cloudflare link so you can reach your
# notes from your phone, anywhere. On by default.
#TUNNEL_ENABLED=true
# Path to the cloudflared executable, if Lucid can't find it automatically.
# Leave unset to let Lucid locate or download it.
#CLOUDFLARED_PATH=


# ============================================================
#  Telegram push (OPTIONAL, off by default)
# ============================================================
#  Telegram is NOT required and is off unless you turn it on here. If enabled,
#  Lucid can also push a short summary to a Telegram bot when a note is ready.
#TELEGRAM_ENABLED=false
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_CHAT_ID=
