tmp_ret = collect_all('openai')
datas += tmp_ret[0]; binaries += tmp_ret[1]; hiddenimports += tmp_ret[2]


a = Analysis(
    ['lucid_app.py'],
    pathex=[],
    binaries=binaries,
    datas=datas,
    hiddenimports=hiddenimports,
    hookspath=[],
    hooksconfig={},
    runtime_hooks=[],
    excludes=['torch', 'resemblyzer', 'server.pipeline.voiceid', 'matplotlib', 'tkinter', 'PyQt5', 'PySide6'],
    noarchive=False,
    optimize=0,
